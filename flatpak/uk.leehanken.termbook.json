{
  "app-id": "dev.termbook.Termbook",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "termbook",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--filesystem=home",
    "--talk-name=org.freedesktop.portal.Desktop"
  ],
  "modules": [
    {
      "name": "termbook",
      "buildsystem": "simple",
      "build-commands": [
        "python3 -m pip install --prefix=/app --ignore-installed --no-index --find-links=flatpak/vendor Pillow==11.0.0 pygments==2.18.0",
        "python3 setup.py install --prefix=/app"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
